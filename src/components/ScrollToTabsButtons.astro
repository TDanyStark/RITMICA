---
import { URL_BASE } from "@/config";
import BtnKnowPortfolio from "./BtnKnowPortfolio.astro";

interface Props {
  targetId: string;
}

const { targetId = "cv-tabs" } = Astro.props;
---

<div class="mt-6 flex flex-col md:flex-row justify-between gap-4 items-center">
  <BtnKnowPortfolio url={`${URL_BASE}/pdfs/31-03-2026 portafolio APP RÍTMICA_Antiinfecciosos.pdf`} />
  <button
    type="button"
    class="p-2 bg-pink-abbott text-white rounded-full shadow-md hover:opacity-95"
    onclick={`document.getElementById("${targetId}")?.scrollIntoView({behavior: 'smooth', block: 'start'});`}
  >
    <span class="sr-only">Ir a pestañas</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-6 h-6 inline-block"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M5 15l7-7 7 7"></path>
    </svg>
  </button>
</div>
